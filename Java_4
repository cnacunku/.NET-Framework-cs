import java.io.*;
import java.util.Scanner;

public class MatrixUtils {
    
    // Чтение int матрицы (для задания 18)
    public static int[][] readIntMatrixFromFile(String filename) throws IOException {
        try (Scanner sc = new Scanner(new File(filename))) {

            if (!sc.hasNextLine()) {
                throw new IOException("Файл пустой");
            }

            String[] dim = sc.nextLine().trim().split("\\s+");
            if (dim.length != 2) {
                throw new IOException("Первая строка должна содержать rows cols");
            }

            int rows = Integer.parseInt(dim[0]);
            int cols = Integer.parseInt(dim[1]);

            if (rows <= 0 || cols <= 0) {
                throw new IOException("Некорректные размеры матрицы");
            }

            int[][] mat = new int[rows][cols];

            for (int i = 0; i < rows; i++) {
                if (!sc.hasNextLine()) {
                    throw new IOException("Недостаточно строк в файле");
                }

                String[] vals = sc.nextLine().trim().split("\\s+");
                if (vals.length != cols) {
                    throw new IOException("Строка " + (i + 1) + " содержит неверное количество элементов");
                }

                for (int j = 0; j < cols; j++) {
                    mat[i][j] = Integer.parseInt(vals[j]);
                }
            }

            return mat;
        }
    }

    // Чтение boolean матрицы (для задания 19, формат 0/1)
    public static boolean[][] readBoolMatrixFromFile(String filename) throws IOException {
        try (Scanner sc = new Scanner(new File(filename))) {

            if (!sc.hasNextLine()) {
                throw new IOException("Файл пустой");
            }

            String[] dim = sc.nextLine().trim().split("\\s+");
            if (dim.length != 2) {
                throw new IOException("Первая строка должна содержать rows cols");
            }

            int rows = Integer.parseInt(dim[0]);
            int cols = Integer.parseInt(dim[1]);

            if (rows <= 0 || cols <= 0) {
                throw new IOException("Некорректные размеры матрицы");
            }

            boolean[][] mat = new boolean[rows][cols];

            for (int i = 0; i < rows; i++) {
                if (!sc.hasNextLine()) {
                    throw new IOException("Недостаточно строк в файле");
                }

                String[] vals = sc.nextLine().trim().split("\\s+");
                if (vals.length != cols) {
                    throw new IOException("Строка " + (i + 1) + " содержит неверное количество элементов");
                }

                for (int j = 0; j < cols; j++) {
                    int val = Integer.parseInt(vals[j]);
                    if (val != 0 && val != 1) {
                        throw new IOException("Допустимы только значения 0 и 1");
                    }
                    mat[i][j] = (val == 1);
                }
            }

            return mat;
        }
    }
    
    // Запись результатов - Yes/No для задания 18
    public static void writeBooleanResult(String filename, boolean result) throws IOException {
        try (PrintWriter pw = new PrintWriter(filename)) {
            pw.println(result ? "Yes" : "No");
        }
    }

    // Запись результатов - координаты прямоугольника (для задания 19)
    public static void writeRectangleResult(String filename, int[] rect) throws IOException {
        try (PrintWriter pw = new PrintWriter(filename)) {
            pw.printf("%d %d %d %d%n", rect[0], rect[1], rect[2], rect[3]);
        }
    }
    
    // Проверка прямоугольности
    public static boolean isRectangular(int[][] mat) {
        if (mat == null || mat.length == 0) return true;
        int cols = mat[0].length;
        for (int[] row : mat) {
            if (row == null || row.length != cols) return false;
        }
        return true;
    }

    // Задание 18 - спираль
    public static boolean isSpiralOrdered(int[][] mat) {
        if (mat == null || mat.length == 0 || mat[0].length == 0) {
            return true;
        }

        int rows = mat.length;
        int cols = mat[0].length;

        int top = 0, bottom = rows - 1;
        int left = 0, right = cols - 1;

        Integer prev = null;

        while (top <= bottom && left <= right) {

            for (int j = left; j <= right; j++) {
                int val = mat[top][j];
                if (prev != null && val <= prev) return false;
                prev = val;
            }
            top++;

            for (int i = top; i <= bottom; i++) {
                int val = mat[i][right];
                if (prev != null && val <= prev) return false;
                prev = val;
            }
            right--;

            if (top <= bottom) {
                for (int j = right; j >= left; j--) {
                    int val = mat[bottom][j];
                    if (prev != null && val <= prev) return false;
                    prev = val;
                }
                bottom--;
            }

            if (left <= right) {
                for (int i = bottom; i >= top; i--) {
                    int val = mat[i][left];
                    if (prev != null && val <= prev) return false;
                    prev = val;
                }
                left++;
            }
        }

        return true;
    }


    // Задание 19 - Максимальный прямоугольник true
    public static int[] findMaxTrueRectangle(boolean[][] mat) {

        if (mat == null || mat.length == 0 || mat[0].length == 0) {
            return new int[]{-1, -1, -1, -1};
        }

        int rows = mat.length;
        int cols = mat[0].length;

        int bestArea = 0;
        int bestR = -1, bestC = -1, bestH = -1, bestW = -1;

        for (int r = 0; r < rows; r++) {
            for (int c = 0; c < cols; c++) {

                if (!mat[r][c]) continue;

                for (int h = 1; r + h <= rows; h++) {
                    for (int w = 1; c + w <= cols; w++) {

                        if (!isAllTrue(mat, r, c, h, w)) break;

                        if (!isBorderFalse(mat, r, c, h, w)) continue;

                        int area = h * w;

                        if (area > bestArea ||
                                (area == bestArea && (r < bestR || (r == bestR && c < bestC)))) {

                            bestArea = area;
                            bestR = r;
                            bestC = c;
                            bestH = h;
                            bestW = w;
                        }
                    }
                }
            }
        }

        if (bestArea == 0) {
            return new int[]{-1, -1, -1, -1};
        }

        return new int[]{bestR, bestC, bestH, bestW};
    }


    // Вспомогательные для прямоугольника
    private static boolean isAllTrue(boolean[][] mat, int r, int c, int h, int w) {
        for (int i = r; i < r + h; i++) {
            for (int j = c; j < c + w; j++) {
                if (!mat[i][j]) return false;
            }
        }
        return true;
    }
    
    private static boolean isBorderFalse(boolean[][] mat, int r, int c, int h, int w) {
        int rows = mat.length;
        int cols = mat[0].length;

        for (int i = r - 1; i <= r + h; i++) {
            for (int j = c - 1; j <= c + w; j++) {

                if (i >= r && i < r + h && j >= c && j < c + w) continue;

                if (i >= 0 && i < rows && j >= 0 && j < cols) {
                    if (mat[i][j]) return false;
                }
            }
        }

        return true;
    }

    public static boolean[][] readMatrix(Scanner sc, int rows, int cols) {
        boolean[][] mat = new boolean[rows][cols];

        System.out.println("Введите элементы матрицы (0 или 1):");

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {

                while (!sc.hasNextInt()) {
                    System.out.print("Введите 0 или 1: ");
                    sc.next();
                }

                int val = sc.nextInt();
                if (val != 0 && val != 1) {
                    System.out.print("Только 0 или 1. Повторите: ");
                    j--;
                    continue;
                }

                mat[i][j] = (val == 1);
            }
        }

        return mat;
    }
    
    public static void printMatrix(boolean[][] mat) {
        for (boolean[] row : mat) {
            for (boolean val : row) {
                System.out.print((val ? "1 " : "0 "));
            }
            System.out.println();
        }
    }
    
    public static boolean isSpiral(boolean[][] mat) {
        int rows = mat.length;
        int cols = mat[0].length;

        int[][] converted = new int[rows][cols];

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                converted[i][j] = mat[i][j] ? 1 : 0;
            }
        }

        return isSpiralOrdered(converted);
    }
