import utils.MatrixUtils;

import java.io.IOException;

public class Task8 {

    public static class InputArgs {
        public String inputFile;
        public String outputFile;
        public int task; // 18 или 19

        public InputArgs(String inputFile, String outputFile, int task) {
            this.inputFile = inputFile;
            this.outputFile = outputFile;
            this.task = task;
        }
    }

    public static void main(String[] args) {
        InputArgs params = parseCmdArgs(args);

        try {
            if (params.task == 18) {
                // Задание 18 — спираль
                int[][] matrix = MatrixUtils.readIntMatrixFromFile(params.inputFile);
                boolean result = MatrixUtils.isSpiralOrdered(matrix);
                MatrixUtils.writeBooleanResult(params.outputFile, result);

            } else if (params.task == 19) {
                // Задание 19 — максимальный прямоугольник
                boolean[][] matrix = MatrixUtils.readBoolMatrixFromFile(params.inputFile);
                int[] rect = MatrixUtils.findMaxTrueRectangle(matrix);
                MatrixUtils.writeRectangleResult(params.outputFile, rect);

            } else {
                System.err.println("Неверный номер задания: " + params.task);
                System.exit(1);
            }

        } catch (IOException e) {
            System.err.println("Ошибка работы с файлом: " + e.getMessage());
            System.exit(2);
        }
    }

    // Разбор аргументов командной строки
    public static InputArgs parseCmdArgs(String[] args) {
        String input = null;
        String output = null;
        Integer task = null;

        for (int i = 0; i < args.length; i++) {
            String arg = args[i];

            if (arg.equals("-i") && i + 1 < args.length) {
                input = args[++i];
            } else if (arg.equals("-o") && i + 1 < args.length) {
                output = args[++i];
            } else if (arg.equals("-t") && i + 1 < args.length) {
                task = Integer.parseInt(args[++i]);
            } else if (arg.startsWith("--input-file=")) {
                input = arg.substring("--input-file=".length());
            } else if (arg.startsWith("--output-file=")) {
                output = arg.substring("--output-file=".length());
            } else if (arg.startsWith("--task=")) {
                task = Integer.parseInt(arg.substring("--task=".length()));
            } else {
                System.err.println("Неверный параметр: " + arg);
                System.exit(1);
            }
        }

        if (input == null || output == null || task == null) {
            System.err.println("Не указаны все обязательные параметры.");
            System.err.println("Использование: -i <input> -o <output> -t <18|19>");
            System.exit(1);
        }

        return new InputArgs(input, output, task);
    }
