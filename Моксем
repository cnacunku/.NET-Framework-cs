using System;
using System.Collections.Generic;
using System.Drawing;
using System.Linq;
using System.Windows.Forms;

namespace CS_TIPIS_6
{
    public partial class Form1 : Form
    {
        public Form1()
        {
            InitializeComponent();
        }

        private void btnStart_Click(object sender, EventArgs e)
        {
            int N = 18;
            int V = 5;

            int points = 120;
            double lambdaMin = 0;
            double lambdaMax = 15;

            double[] lambdaArr = new double[points];
            List<double[]> probs = new List<double[]>();

            for (int i = 0; i <= V; i++)
                probs.Add(new double[points]);

            // Pi(λ)
            for (int k = 0; k < points; k++)
            {
                double lambda = lambdaMin + k * (lambdaMax - lambdaMin) / (points - 1);
                lambdaArr[k] = lambda;

                double denom = 0;
                for (int j = 0; j <= V; j++)
                    denom += Math.Pow(lambda, j) / Factorial(j);

                for (int i = 0; i <= V; i++)
                {
                    double pi = Math.Pow(lambda, i) / Factorial(i) / denom;
                    probs[i][k] = pi;
                }
            }

            DrawGraphPi(pictureBox1, lambdaArr, probs);

            // Характеристики
            double lambda0 = 10.0 * (N + 1) / (N + 4);

            double Pv = ErlangB(lambda0, V);

            double A = lambda0;
            double R = lambda0 * Pv;
            double Y = A - R;

            string resultText =
                "Пункт 2.2:\r\n" +
                $"P0(0) = 1, P_i(0) = 0 (i>0)\r\n" +
                $"P_V(∞) = 1, остальные P_i(∞) = 0\r\n\r\n" +
                "Точки пересечения P_i и P_{i-1}:\r\n" + string.Join("\r\n", Enumerable.Range(1, V).Select(i => $"P{i} = P{i - 1} при Λ = {i}")) +

                "\r\n\r\nПункт 2.3:\r\n" +
                $"λ = {lambda0:F2}\r\n" +
                $"P потерь = {Pv:F4}\r\n" +
                $"A (потенциальная) = {A:F2}\r\n" +
                $"R (потери) = {R:F2}\r\n" +
                $"Y (обслуженная) = {Y:F2}\r\n\r\n";

            textBox1.Text = resultText;
        }

        // Факториал
        private double Factorial(int n)
        {
            double res = 1;
            for (int i = 2; i <= n; i++)
                res *= i;
            return res;
        }

        // Формула Эрланга
        private double ErlangB(double lambda, int V)
        {
            double sum = 0;

            for (int j = 0; j <= V; j++)
                sum += Math.Pow(lambda, j) / Factorial(j);

            return Math.Pow(lambda, V) / Factorial(V) / sum;
        }

        // График
        private void DrawGraphPi(PictureBox box, double[] x, List<double[]> curves)
        {
            Bitmap bmp = new Bitmap(box.Width, box.Height);

            using (Graphics g = Graphics.FromImage(bmp))
            {
                g.Clear(Color.White);

                int margin = 60;

                double xMin = x.Min();
                double xMax = x.Max();
                double yMin = 0;
                double yMax = 1;

                // Сетка
                using (Pen gridPen = new Pen(Color.LightGray))
                {
                    for (int i = 0; i <= 15; i++)
                    {
                        float px = margin + (float)((double)i / 15 * (box.Width - 2 * margin));
                        g.DrawLine(gridPen, px, margin, px, box.Height - margin);
                    }

                    for (int i = 0; i <= 10; i++)
                    {
                        float py = box.Height - margin - (float)((double)i / 10 * (box.Height - 2 * margin));
                        g.DrawLine(gridPen, margin, py, box.Width - margin, py);
                    }
                }

                // Оси
                using (Pen axisPen = new Pen(Color.Black, 2))
                {
                    g.DrawLine(axisPen, margin, margin, margin, box.Height - margin);
                    g.DrawLine(axisPen, margin, box.Height - margin, box.Width - margin, box.Height - margin);
                }

                using (Font font = new Font("Tahoma", 9))
                {
                    // X (λ)
                    for (int i = 0; i <= 15; i++)
                    {
                        float px = margin + (float)((double)i / 15 * (box.Width - 2 * margin));

                        g.DrawLine(Pens.Black, px, box.Height - margin, px, box.Height - margin + 5);
                        g.DrawString(i.ToString(), font, Brushes.Black, px - 10, box.Height - margin + 8);
                    }

                    // Y (Pi)
                    for (int i = 0; i <= 10; i++)
                    {
                        double val = i * 0.1;

                        float py = box.Height - margin - (float)((double)i / 10 * (box.Height - 2 * margin));

                        g.DrawLine(Pens.Black, margin - 5, py, margin, py);
                        g.DrawString(val.ToString("0.0"), font, Brushes.Black, margin - 45, py - 7);
                    }
                }

                // Графики
                for (int i = 0; i < curves.Count; i++)
                {
                    Color color = ColorFromIndex(i);

                    using (Pen pen = new Pen(color, 2))
                    {
                        List<PointF> pts = new List<PointF>();

                        for (int k = 0; k < x.Length; k++)
                        {
                            float px = margin + (float)((x[k] - xMin) / (xMax - xMin) * (box.Width - 2 * margin));
                            float py = box.Height - margin - (float)((curves[i][k] - yMin) / (yMax - yMin) * (box.Height - 2 * margin));

                            pts.Add(new PointF(px, py));
                        }

                        if (pts.Count > 1)
                            g.DrawLines(pen, pts.ToArray());
                    }
                }

                // Подписи
                using (Font fontBold = new Font("Tahoma", 12, FontStyle.Bold))
                {
                    g.DrawString("Pi(λ)", fontBold, Brushes.Black, 5, 5);
                    g.DrawString("λ", fontBold, Brushes.Black, box.Width / 2, box.Height - 30);
                }

                // Легенда
                using (Font font = new Font("Tahoma", 12))
                {
                    for (int i = 0; i < curves.Count; i++)
                    {
                        g.DrawString($"P{i}", font, new SolidBrush(ColorFromIndex(i)), margin + i * 30, 25);
                    }
                }
            }

            if (box.Image != null)
                box.Image.Dispose();

            box.Image = bmp;
        }

        // Цвета 
        private Color ColorFromIndex(int i)
        {
            Color[] colors = {
                Color.Blue,
                Color.Green,
                Color.Red,
                Color.Purple,
                Color.Orange,
                Color.Brown
            };

            return colors[i % colors.Length];
        }
    }
}
