using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace tipisSKY
{
    public partial class tipis_WF : Form
    {       
        static Random rnd = new Random();

        public tipis_WF()
        {
            InitializeComponent();
        }

        private double mid()
        {
            return -2 + 9 * rnd.NextDouble();
        }

        private double[] generate(int n)
        {
            double[] data = new double[n];
            for (int i = 0; i < n; i++)
                data[i] = mid();
            return data;
        }

        public void draw(double[] data, PictureBox pb)
        {
            int bins = 9;
            int[] counts = new int[bins];

            foreach (var x in data)
            {
                int index = (int)(x + 2);
                if (index >= bins) index = bins - 1;
                counts[index]++;
            }

            int maxCount = 0;
            foreach (var c in counts)
                if (c > maxCount) maxCount = c;

            Bitmap bmp = new Bitmap(pb.Width, pb.Height);
            Graphics g = Graphics.FromImage(bmp);
            g.Clear(Color.White);

            int barWidth = pb.Width / bins;

            for (int i = 0; i < bins; i++)
            {
                int barHeight = (int)((counts[i] / (double)maxCount) * (pb.Height - 20));
                g.FillRectangle(Brushes.Gray, i * barWidth, pb.Height - barHeight, barWidth - 2, barHeight);

                g.DrawString(counts[i].ToString(), new Font("Times New Roman", 10), Brushes.Black,
                    i * barWidth + 2, pb.Height - barHeight - 15);
            }

            pb.Image = bmp;
        }

        private void draw2(PictureBox pb)
        {
            int[] values = { 5, 7, 17, 19, 21, 25, 55 };
            double[] probs = { 0.01, 0.05, 0.3, 0.3, 0.3, 0.02, 0.02 };
            int bins = values.Length;
            int[] counts = new int[bins];

            Random rnd = new Random();
            int n = 100000;

            for (int i = 0; i < n; i++)
            {
                double r = rnd.NextDouble();
                double sum = 0;
                for (int j = 0; j < bins; j++)
                {
                    sum += probs[j];
                    if (r <= sum)
                    {
                        counts[j]++;
                        break;
                    }
                }
            }

            Bitmap bmp = new Bitmap(pb.Width, pb.Height);
            Graphics g = Graphics.FromImage(bmp);
            g.Clear(Color.White);

            int maxCount = 0;
            foreach (var c in counts)
                if (c > maxCount) maxCount = c;

            int barWidth = pb.Width / bins;

            for (int i = 0; i < bins; i++)
            {
                int barHeight = (int)((counts[i] / (double)maxCount) * (pb.Height - 50));

                g.FillRectangle(Brushes.Green, i * barWidth, pb.Height - barHeight, barWidth - 5, barHeight);

                g.DrawString(values[i].ToString(), new Font("Times New Roman", 10), Brushes.Black, i * barWidth + 5, pb.Height - 315);

                g.DrawString(counts[i].ToString(), new Font("Times New Roman", 10), Brushes.Black, i * barWidth + 5, pb.Height - barHeight - 20);

            }

            pb.Image = bmp;
        }

        private void button1_Click_1(object sender, EventArgs e)
        {
            double[] smallSample = generate(1000);
            draw(smallSample, pictureBox1);

            double[] largeSample = generate(100000);
            draw(largeSample, pictureBox2);
        }

        private void button2_Click(object sender, EventArgs e)
        {
            draw2(pictureBox3);
        }
    }
}
