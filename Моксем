using System;
using System.Drawing;
using System.Drawing.Imaging;
using System.Windows.Forms;
using Tao.FreeGlut;
using Tao.OpenGl;
using Tao.Platform.Windows;

namespace LAB6_3D
{
    public partial class Form1 : Form
    {
        private float rotX = 20;
        private float rotY = 30;
        private bool isDragging = false;
        private int lastMouseX, lastMouseY;
        private float zoom = 1.0f;
        private uint textureID;

        public Form1()
        {
            InitializeComponent();
            AnT.InitializeContexts();
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            Glut.glutInit();
            Glut.glutInitDisplayMode(Glut.GLUT_RGB | Glut.GLUT_DOUBLE | Glut.GLUT_DEPTH);

            Gl.glClearColor(0.9f, 0.9f, 0.9f, 1f);
            Gl.glViewport(0, 0, AnT.Width, AnT.Height);

            Gl.glMatrixMode(Gl.GL_PROJECTION);
            Gl.glLoadIdentity();
            Glu.gluPerspective(45, (float)AnT.Width / AnT.Height, 0.1, 200);

            Gl.glMatrixMode(Gl.GL_MODELVIEW);
            Gl.glLoadIdentity();

            Gl.glEnable(Gl.GL_DEPTH_TEST);

            // Освещение
            Gl.glEnable(Gl.GL_LIGHTING);
            Gl.glEnable(Gl.GL_LIGHT0);
            float[] lightPos = { 5f, 5f, 5f, 1f };
            float[] lightColor = { 1f, 1f, 1f, 1f };
            Gl.glLightfv(Gl.GL_LIGHT0, Gl.GL_POSITION, lightPos);
            Gl.glLightfv(Gl.GL_LIGHT0, Gl.GL_DIFFUSE, lightColor);
            Gl.glLightfv(Gl.GL_LIGHT0, Gl.GL_SPECULAR, lightColor);

            Gl.glEnable(Gl.GL_COLOR_MATERIAL);
            Gl.glColorMaterial(Gl.GL_FRONT, Gl.GL_AMBIENT_AND_DIFFUSE);

            // Текстуры
            Gl.glEnable(Gl.GL_TEXTURE_2D);
            LoadTexture();

            // События мыши
            AnT.MouseDown += AnT_MouseDown;
            AnT.MouseUp += AnT_MouseUp;
            AnT.MouseMove += AnT_MouseMove;
            AnT.MouseWheel += AnT_MouseWheel;
        }

        private void LoadTexture()
        {
            Bitmap image = new Bitmap(@"C:\Users\admin\Desktop\текстура.jpg");
            image.RotateFlip(RotateFlipType.RotateNoneFlipY);

            BitmapData data = image.LockBits(
                new Rectangle(0, 0, image.Width, image.Height),
                ImageLockMode.ReadOnly,
                PixelFormat.Format24bppRgb
            );

            Gl.glGenTextures(1, out textureID);
            Gl.glBindTexture(Gl.GL_TEXTURE_2D, textureID);

            Gl.glTexParameteri(Gl.GL_TEXTURE_2D, Gl.GL_TEXTURE_MIN_FILTER, Gl.GL_LINEAR);
            Gl.glTexParameteri(Gl.GL_TEXTURE_2D, Gl.GL_TEXTURE_MAG_FILTER, Gl.GL_LINEAR);

            Gl.glTexImage2D(
                Gl.GL_TEXTURE_2D, 0, Gl.GL_RGB,
                data.Width, data.Height, 0,
                Gl.GL_BGR, Gl.GL_UNSIGNED_BYTE, data.Scan0
            );

            image.UnlockBits(data);
        }

        private void buttonExit_Click(object sender, EventArgs e)
        {
            Application.Exit();
        }

        private void buttonRender_Click(object sender, EventArgs e)
        {
            DrawScene();
        }

        private void DrawScene()
        {
            Gl.glClear(Gl.GL_COLOR_BUFFER_BIT | Gl.GL_DEPTH_BUFFER_BIT);
            Gl.glLoadIdentity();

            Gl.glTranslatef(0, 0, -6);
            Gl.glScalef(zoom, zoom, zoom);
            Gl.glRotatef(rotX, 1, 0, 0);
            Gl.glRotatef(rotY, 0, 1, 0);

            // 1. Цилиндр
            Gl.glPushMatrix();
            Gl.glColor3f(1.0f, 1.0f, 1.0f);
            Gl.glTranslatef(0, -1.7f, 0);
            DrawClosedCylinder();
            Gl.glPopMatrix();

            // 2. Чайник
            Gl.glDisable(Gl.GL_TEXTURE_2D);
            Gl.glColor3f(1.0f, 0.4f, 0.7f);
            Glut.glutSolidTeapot(1.5);
            Gl.glEnable(Gl.GL_TEXTURE_2D);

            // 3. Тор
            Gl.glPushMatrix();
            Gl.glTranslatef(0, 2.6f, 0);

            Gl.glRotatef(180, 0, 1, 0);

            Gl.glColor3f(0.2f, 0.6f, 1.0f);
            Glut.glutWireTorus(0.35, 1, 25, 35);
            Gl.glPopMatrix();
            

            AnT.Invalidate();
        }

        private void AnT_MouseWheel(object sender, MouseEventArgs e)
        {
            if (e.Delta > 0)
                zoom += 0.1f;
            else
                zoom -= 0.1f;

            if (zoom < 0.1f) zoom = 0.1f;
            if (zoom > 5f) zoom = 5f;

            DrawScene();
        }

        private void DrawClosedCylinder()
        {
            Gl.glBindTexture(Gl.GL_TEXTURE_2D, textureID);

            int slices = 40;
            float radius = 1.2f;
            float height = 0.5f;

            Gl.glBegin(Gl.GL_QUAD_STRIP);
            for (int i = 0; i <= slices; i++)
            {
                double angle = 2.0 * Math.PI * i / slices;
                float x = (float)Math.Cos(angle);
                float z = (float)Math.Sin(angle);

                Gl.glTexCoord2f((float)i / slices, 0);
                Gl.glVertex3f(radius * x, -height, radius * z);

                Gl.glTexCoord2f((float)i / slices, 1);
                Gl.glVertex3f(radius * x, height, radius * z);
            }
            Gl.glEnd();

            Gl.glBegin(Gl.GL_TRIANGLE_FAN);
            Gl.glTexCoord2f(0.5f, 0.5f);
            Gl.glVertex3f(0, -height, 0);
            for (int i = 0; i <= slices; i++)
            {
                double angle = 2.0 * Math.PI * i / slices;
                float x = (float)Math.Cos(angle);
                float z = (float)Math.Sin(angle);
                Gl.glTexCoord2f(0.5f + 0.5f * x, 0.5f + 0.5f * z);
                Gl.glVertex3f(radius * x, -height, radius * z);
            }
            Gl.glEnd();

            // Верхняя крышка
            Gl.glBegin(Gl.GL_TRIANGLE_FAN);
            Gl.glTexCoord2f(0.5f, 0.5f);
            Gl.glVertex3f(0, height, 0);
            for (int i = 0; i <= slices; i++)
            {
                double angle = 2.0 * Math.PI * i / slices;
                float x = (float)Math.Cos(angle);
                float z = (float)Math.Sin(angle);
                Gl.glTexCoord2f(0.5f + 0.5f * x, 0.5f + 0.5f * z);
                Gl.glVertex3f(radius * x, height, radius * z);
            }
            Gl.glEnd();
        }

        private void AnT_MouseDown(object sender, MouseEventArgs e)
        {
            if (e.Button == MouseButtons.Left)
            {
                isDragging = true;
                lastMouseX = e.X;
                lastMouseY = e.Y;
            }
        }

        private void AnT_MouseUp(object sender, MouseEventArgs e)
        {
            if (e.Button == MouseButtons.Left)
                isDragging = false;
        }

        private void AnT_MouseMove(object sender, MouseEventArgs e)
        {
            if (isDragging)
            {
                int dx = e.X - lastMouseX;
                int dy = e.Y - lastMouseY;
                rotY += dx;
                rotX += dy;
                lastMouseX = e.X;
                lastMouseY = e.Y;
                DrawScene();
            }
        }
    }
}
